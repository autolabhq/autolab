FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends tmux && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir "numpy==1.26.4"

WORKDIR /app

# Copy source files
COPY datagen.py  /app/datagen.py
COPY main.py     /app/main.py
COPY predictor.py /app/predictor.py

# Generate visible data at build time (hidden data generated by verifier at runtime)
RUN python3 /app/datagen.py --seed 2024 --output-dir /app/data/visible

# Tamper detection: save SHA256 hashes of protected files
RUN mkdir -p /orig && \
    sha256sum /app/main.py     > /orig/main.py.sha256 && \
    sha256sum /app/datagen.py  > /orig/datagen.py.sha256

# Smoke test: verify baseline predictor works
RUN python3 /app/main.py

RUN mkdir -p /logs/verifier

RUN echo "=== System Info ===" && \
    (which gcc && gcc --version | head -1 || true) && \
    (which python3 && python3 --version || true) && \
    (pip list 2>/dev/null || pip3 list 2>/dev/null || true) && \
    echo "=== End System Info ==="

CMD ["bash"]
